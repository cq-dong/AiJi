# AiJi 后端环境变量。复制为 .env 填真实值。.env 已 gitignore。
# 缺 JWT_SECRET / REFRESH_SECRET 启动会 throw。

# JWT access token 签名密钥（HS256，≥32 字节）。生成：openssl rand -base64 48
JWT_SECRET=

# refresh token 服务端密钥（用于 sha256 hash，≥32 字节）。生成：openssl rand -base64 48
REFRESH_SECRET=

# DeepSeek LLM 代理 key（builtin LLM 走这个）
DEEPSEEK_KEY=
DEEPSEEK_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 阿里云 DashScope STT 代理 key（builtin STT 走文件转写 REST；VLM 多模态复用同 key）
DASHSCOPE_KEY=
DASHSCOPE_BASE=https://dashscope.aliyuncs.com

# VLM 多模态模型名（qwen-vl 系列），缺省 qwen-vl-max-latest
VLM_MODEL=qwen-vl-max-latest

# CORS 允许的 origin，逗号分隔。dev 含 localhost；APK WebView origin 是 https://localhost 必须放行
CORS_ORIGINS=http://localhost:5173,https://localhost,http://localhost:8787

# 服务端口
PORT=8787

# JWT access token 有效期（秒），默认 900=15min
JWT_TTL_SECONDS=900

# refresh token 有效期（秒），默认 2592000=30天
REFRESH_TTL_SECONDS=2592000
